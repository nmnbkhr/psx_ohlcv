# PSX OHLCV — Environment Configuration
# Copy to .env and adjust values for your setup.

# Database — SQLite file path
PSX_DB_PATH=/mnt/e/psxdata/psx.sqlite

# Data root directory (backups, csv, logs stored here)
PSX_DATA_ROOT=/mnt/e/psxdata

# AI Provider: "openai" or "anthropic"
PSX_LLM_PROVIDER=openai

# API Keys (leave blank to disable AI features)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Sync settings
# PSX_SYNC_CONCURRENT=25
# PSX_SYNC_RATE_LIMIT=0.05

# API server
# PSX_API_HOST=0.0.0.0
# PSX_API_PORT=8000
